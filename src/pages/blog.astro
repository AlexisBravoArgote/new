---
import Layout from '../layouts/Layout.astro';
import BlogClient from '../components-react/BlogContent.jsx';
import { STATIC_PAGE_SEO } from '../config/seo-static-pages.js';
import { buildJsonLd, breadcrumbSchema, dentalClinicOrganization } from '../lib/seo.js';

const seo = STATIC_PAGE_SEO.blog;

const structuredData = buildJsonLd(
    dentalClinicOrganization(),
    {
        "@type": "Blog",
        name: "Blog Dental City",
        description: seo.description,
        url: "https://dentalcity.mx/blog",
        publisher: { "@id": "https://dentalcity.mx/#organization" },
    },
    breadcrumbSchema([
        { name: "Inicio", path: "/" },
        { name: "Blog", path: "/blog" },
    ])
);
---

<Layout
    title={seo.title}
    description={seo.description}
    keywords={seo.keywords}
    structuredData={structuredData}
>
    <BlogClient client:load />
</Layout>

<style>
    @import "../styles/global.css";
</style>
