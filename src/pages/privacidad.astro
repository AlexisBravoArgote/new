---
import Layout from '../layouts/Layout.astro';
import PrivacidadClient from '../components-react/PrivacidadContent.jsx';
import { STATIC_PAGE_SEO } from '../config/seo-static-pages.js';
import { breadcrumbSchema, buildJsonLd, dentalClinicOrganization } from '../lib/seo.js';

const seo = STATIC_PAGE_SEO.privacidad;

const structuredData = buildJsonLd(
    dentalClinicOrganization(),
    breadcrumbSchema([
        { name: "Inicio", path: "/" },
        { name: "Aviso de privacidad", path: "/privacidad" },
    ])
);
---

<Layout
    title={seo.title}
    description={seo.description}
    keywords={seo.keywords}
    structuredData={structuredData}
>
    <PrivacidadClient client:load />
</Layout>

<style>
    @import "../styles/global.css";
</style>
