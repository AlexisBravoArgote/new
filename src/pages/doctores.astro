---
import Layout from '../layouts/Layout.astro';
import DoctoresContent from '../components-react/DoctoresContent.jsx';
import { getAlternateLinks, getPageSeo } from '../lib/site-copy.js';
import { buildJsonLd, dentalClinicOrganization, breadcrumbSchema } from '../lib/seo.js';

const seo = getPageSeo('doctores', 'es');

const structuredData = buildJsonLd(
    dentalClinicOrganization({
        description: seo.description,
        numberOfEmployees: { "@type": "QuantitativeValue", value: "29" },
    }),
    breadcrumbSchema([
        { name: "Inicio", path: "/" },
        { name: "Nuestros doctores", path: "/doctores" },
    ])
);
---

<Layout
    lang="es"
    title={seo.title}
    description={seo.description}
    keywords={seo.keywords}
    alternates={getAlternateLinks('doctores')}
    structuredData={structuredData}
>
    <DoctoresContent client:load lang="es" />
</Layout>

<style>
    @import "../styles/global.css";
</style>
