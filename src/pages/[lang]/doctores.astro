---
import Layout from '../../layouts/Layout.astro';
import DoctoresContent from '../../components-react/DoctoresContent.jsx';
import { SECONDARY_LOCALE_CODES } from '../../config/languages.js';
import { getAlternateLinks, getPageSeo, normalizeLang } from '../../lib/site-copy.js';
import { buildJsonLd, breadcrumbSchema, dentalClinicOrganization } from '../../lib/seo.js';

export function getStaticPaths() {
    return SECONDARY_LOCALE_CODES.map((lang) => ({ params: { lang } }));
}

const { lang: rawLang } = Astro.params;
const lang = normalizeLang(rawLang);
const seo = getPageSeo('doctores', lang);

const structuredData = buildJsonLd(
    dentalClinicOrganization({
        description: seo.description,
        numberOfEmployees: { "@type": "QuantitativeValue", value: "29" },
    }),
    breadcrumbSchema([
        { name: "Inicio", path: lang === "es" ? "/" : `/${lang}/` },
        { name: seo.title, path: lang === "es" ? "/doctores" : `/${lang}/doctores` },
    ])
);
---

<Layout
    lang={lang}
    title={seo.title}
    description={seo.description}
    keywords={seo.keywords}
    alternates={getAlternateLinks('doctores')}
    structuredData={structuredData}
>
    <DoctoresContent client:load lang={lang} />
</Layout>

<style>
    @import "../../styles/global.css";
</style>
