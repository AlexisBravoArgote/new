---
import Layout from '../../layouts/Layout.astro';
import TreatmentContent from '../../components-react/TreatmentContent.jsx';
import { TREATMENT_SLUGS } from '../../data/treatmentSlugs.js';
import esTreatments from '../../locales/es/treatments.json';
import {
    buildJsonLd,
    breadcrumbSchema,
    dentalClinicOrganization,
    medicalProcedureSchema,
} from '../../lib/seo.js';

export function getStaticPaths() {
    return TREATMENT_SLUGS.map((slug) => ({ params: { slug } }));
}

const { slug } = Astro.params;
const treatment = esTreatments.byService[slug];
const pageTitle = treatment?.pageTitle ?? 'Tratamiento dental';
const description =
    treatment?.heroSubtitle ??
    `Tratamiento de ${pageTitle} en Dental City, clínica dental en Zapopan, Jalisco.`;
const keywords = [
    pageTitle,
    'Dental City',
    'clínica dental Zapopan',
    'dentista Guadalajara',
    'tratamiento dental',
    slug.replace(/-/g, ' '),
].join(', ');

const structuredData = buildJsonLd(
    dentalClinicOrganization(),
    breadcrumbSchema([
        { name: 'Inicio', path: '/' },
        { name: 'Tratamientos', path: '/#servicios' },
        { name: pageTitle, path: `/tratamientos/${slug}` },
    ]),
    medicalProcedureSchema({ name: pageTitle, description, slug })
);
---

<Layout
    title={pageTitle}
    description={description}
    keywords={keywords}
    structuredData={structuredData}
>
    <TreatmentContent client:load slug={slug} />
</Layout>
