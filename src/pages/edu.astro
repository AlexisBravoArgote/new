---
import Layout from '../layouts/Layout.astro';
import EduClient from '../components-react/EduContent.jsx';
import { STATIC_PAGE_SEO } from '../config/seo-static-pages.js';
import { buildJsonLd, breadcrumbSchema, dentalClinicOrganization } from '../lib/seo.js';

const seo = STATIC_PAGE_SEO.edu;

const structuredData = buildJsonLd(
    dentalClinicOrganization(),
    {
        "@type": "EducationalOrganization",
        name: "Dental City Edu",
        description: seo.description,
        url: "https://dentalcity.mx/edu",
        provider: { "@id": "https://dentalcity.mx/#organization" },
    },
    breadcrumbSchema([
        { name: "Inicio", path: "/" },
        { name: "Dental City Edu", path: "/edu" },
    ])
);
---

<Layout
    title={seo.title}
    description={seo.description}
    keywords={seo.keywords}
    structuredData={structuredData}
>
    <EduClient client:load />
</Layout>

<style>
    @import "../styles/global.css";
</style>
